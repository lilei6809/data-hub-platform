{
  "realm": "data-hub-local",
  "enabled": true,
  "displayName": "Data Hub Local",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "roles": {
    "realm": [
      {
        "name": "platform-admin",
        "description": "Local platform operator role"
      },
      {
        "name": "tenant-operator",
        "description": "Local tenant operator role"
      }
    ]
  },
  "clients": [
    {
      "clientId": "data-hub-admin-ui",
      "name": "Data Hub Admin UI",
      "enabled": true,
